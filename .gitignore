# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.idea
/docs
/.claude
/.husky
/.playwright-mcp
/.serena

